# AWS Bedrock (ap-northeast-2 기본값, us 리전은 us.anthropic.claude-3-5-sonnet-20241022-v2:0)
AWS_REGION=ap-northeast-2
BEDROCK_MODEL_ID=apac.anthropic.claude-3-5-sonnet-20241022-v2:0

# S3 (작업계획서 + Terraform 결과 저장)
S3_BUCKET=dndn-reports

# GitHub (Terraform 코드 스타일 참조용)
GITHUB_TOKEN=ghp_xxxx
GITHUB_REPO=your-org/your-terraform-repo

# CORS (쉼표로 구분, 기본값: localhost:3000,5173)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
