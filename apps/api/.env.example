# ── AWS ───────────────────────────────────
AWS_REGION=us-east-1
S3_BUCKET=                                      # 필수 — 문서 HTML/Terraform 저장 버킷

# ── Cognito ───────────────────────────────
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── STS (Cross-Account) ──────────────────
STS_ROLE_NAME=DnDnOpsAgentRole
STS_EXTERNAL_ID=dndn-ops-agent                  # 필수 — 미설정 시 서버 시작 실패
PLATFORM_ACCOUNT_ID=451017115109                 # 필수 — 미설정 시 서버 시작 실패
CFN_TEMPLATE_URL=https://dndn-cfn-templates.s3.amazonaws.com/cfn/dndn-ops-agent-role.yaml  # 필수

# ── GitHub OAuth ──────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5173/auth/github/callback

# ── Slack OAuth ───────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://www.dndn.cloud/auth/slack/callback

# ── EventBridge Scheduler ─────────────────
# terraform output scheduler_group_name
SCHEDULER_GROUP_NAME=dndn-schedules
# terraform output scheduler_role_arn
SCHEDULER_ROLE_ARN=arn:aws:iam::387721658341:role/dndn-PRD-EBS-SchedulerRole
# terraform output scheduler_trigger_lambda_arn
SCHEDULER_TARGET_ARN=arn:aws:lambda:ap-northeast-2:387721658341:function:dndn-prd-lmd-scheduler-trigger

# ── SQS (보고서 생성 요청 큐) ──────────────
# terraform output report_request_queue_url
REPORT_REQUEST_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/387721658341/dndn-prd-sqs-report-request

# ── 내부 인증 (Lambda → API) ───────────────
# dndn-infra terraform var.internal_api_key 와 동일한 값으로 설정
INTERNAL_API_KEY=
